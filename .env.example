# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# Secure Database Password
DB_PASSWORD=PLACEHOLDER

# Base64-encoded debug.keystore key for signing the application
DEBUG_KEYSTORE_BASE64=PLACEHOLDER

# Microfinance Credentials and Firebase Sync Configurations
# Move these database secrets out of client hardcoding into BuildConfig/environment properties.
FIREBASE_DATABASE_URL=https://collection-app-2007-default-rtdb.asia-southeast1.firebasedatabase.app/
ADMIN_USERNAME=muneeswaran
ADMIN_PASSWORD=PLACEHOLDER
GOOGLE_SCRIPT_URL=PLACEHOLDER
